# Rock PVP Helper Backend local config example
# Copy to backend/.env when you need to override defaults.

APP_ENV=local
DEBUG=true

# Default: project-root/data/app.db
# DATABASE_URL=sqlite:///../data/app.db

# Comma-separated frontend origins for local development.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Data update admin token. If set, admin update APIs require header:
# X-Admin-Token: your-token
ADMIN_UPDATE_TOKEN=

# Data pipeline output directory. Default: project-root/data/rocom
# ROCOM_DATA_DIR=../data/rocom

# Keep startup independent from network crawler by default.
ROCOM_AUTO_UPDATE_ON_STARTUP=false
ROCOM_AUTO_UPDATE_COMMIT=false
ROCOM_AUTO_UPDATE_FORCE=false
ROCOM_AUTO_UPDATE_LIMIT=0
ROCOM_AUTO_UPDATE_WITH_IMAGES=false
ROCOM_UPDATE_DELAY=1.5
